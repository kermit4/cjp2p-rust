{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cjp2p",
  "version": "0.3.0",
  "identifier": "net.azai.cjp2p",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "cjp2p Pong",
        "width": 960,
        "height": 680,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline'; connect-src ws://localhost:24255 wss://localhost:24255"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "shortDescription": "cjp2p Pong – peer-to-peer Pong game",
    "longDescription": "A peer-to-peer Pong game powered by the cjp2p encrypted P2P network.",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "android": {
      "minSdkVersion": 24
    }
  }
}
